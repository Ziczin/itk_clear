```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
.ENV/

# Dependencies
pip-wheel-metadata/
requirements.txt.bak

# Logs
*.log

# Local configuration
.env
.env.local
*.env.*

# Coverage reports
.coverage
htmlcov/
.coverage.*

# Testing
.pytest_cache/
.mypy_cache/
.hypothesis/

# Distribution / packaging
dist/
build/
*.egg-info/
.installed.cfg
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
```